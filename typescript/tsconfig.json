{
  "compilerOptions": {
    "target":    "ES2020",
    "module":    "ESNext",

    /* NodeNext risolve correttamente gli import directory → index.ts
       e gestisce le estensioni .js negli import TS→JS. */
    "moduleResolution": "Bundler",

    "lib": ["ES2020"],
    "outDir":  "./dist",
    "rootDir": "./src",

    "strict":                          true,
    "noImplicitThis":                  true,
    "strictNullChecks":                true,
    "esModuleInterop":                 true,
    "skipLibCheck":                    true,
    "sourceMap":                       true,
    "resolveJsonModule":               true,
    "forceConsistentCasingInFileNames": true,
    "noEmitOnError":                   true,

    /* Permette di usare 'override' nelle sottoclassi */
    "noImplicitOverride": false
  },
  "include": ["src"],
  "exclude": ["node_modules", "dist", "dist-cjs"]
}
