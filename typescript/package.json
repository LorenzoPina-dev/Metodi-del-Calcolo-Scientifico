{
  "name": "numeric-matrix",
  "version": "1.0.0",
  "description": "Generic matrix library for Float64, Complex and exact Rational arithmetic.",
  "author": "",
  "license": "SEE LICENSE IN LICENSE",
  "type": "module",
  "main": "./dist/cjs/index.js",
  "module": "./dist/esm/index.js",
  "types": "./dist/types/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/esm/index.js",
      "require": "./dist/cjs/index.js",
      "types": "./dist/types/index.d.ts"
    }
  },
  "files": [
    "dist/",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build:wasm": "asc src/wasm/matrix_ops.ts --outFile src/wasm/matrix_ops.wasm --optimizeLevel 3 --shrinkLevel 0 --runtime stub --noAssert --enable simd",
    "build:wasmpar": "asc src/wasm/matrix_ops.ts --outFile src/wasm/matrix_ops.wasm -O3 --runtime stub --noAssert --enable simd --enable threads --importMemory --sharedMemory --initialMemory 256 --maximumMemory 4096",
    "build:wasm:nosimd": "asc src/wasm/matrix_ops.ts --outFile src/wasm/matrix_ops.wasm --optimizeLevel 3 --shrinkLevel 0 --runtime stub --noAssert",
    "build:esm": "tsc --project tsconfig.esm.json",
    "build:cjs": "tsc --project tsconfig.cjs.json",
    "build:types": "tsc --project tsconfig.types.json",
    "build": "npm run build:wasm && npm run build:esm && npm run build:cjs && npm run build:types",
    "test": "vitest",
    "example": "npx tsx src/examples/usage.ts",
    "benchmark": "npx tsx --expose-gc benchmark/benchmark.ts",
    "benchmark:simple": "npx tsx --expose-gc benchmark/benchmark_simple.ts",
    "benchmark:gpu": "npx tsx --expose-gc benchmark/benchmark_gpu.ts",
    "prepublishOnly": "npm run build && npm test"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@webgpu/types": "^0.1.69",
    "assemblyscript": "^0.28.10",
    "tsx": "^4.19.4",
    "typescript": "^5.7.3",
    "vitest": "^4.1.0",
    "webgpu": "^0.3.10"
  },
  "optionalDependencies": {
    "webgpu": "^0.1.0"
  }
}
