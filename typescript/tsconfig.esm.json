{
  "compilerOptions": {
    "target":                           "ES2020",
    "module":                           "ESNext",
    "moduleResolution":                 "Bundler",
    "lib":                              ["ES2020"],

    "outDir":                           "./dist/esm",
    "rootDir":                          "./src",
    "declaration":                      false,
    "declarationMap":                   false,

    "strict":                           true,
    "noImplicitThis":                   true,
    "strictNullChecks":                 true,
    "esModuleInterop":                  true,
    "skipLibCheck":                     true,
    "sourceMap":                        true,
    "resolveJsonModule":                true,
    "forceConsistentCasingInFileNames": true,
    "noEmitOnError":                    true,
    "noImplicitOverride":               false
  },
  "include": ["src"],
  "exclude": ["node_modules", "src/examples", "test"]
}
