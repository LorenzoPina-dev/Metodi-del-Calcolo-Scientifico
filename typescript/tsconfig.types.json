{
  "compilerOptions": {
    "target":                           "ES2020",
    "module":                           "ESNext",
    "moduleResolution":                 "Bundler",
    "lib":                              ["ES2020", "DOM"],

    "outDir":                           "./dist/types",
    "rootDir":                          "./src",
    "declaration":                      true,
    "declarationMap":                   true,
    "emitDeclarationOnly":              true,

    "strict":                           true,
    "noImplicitThis":                   true,
    "strictNullChecks":                 true,
    "esModuleInterop":                  true,
    "skipLibCheck":                     true,
    "resolveJsonModule":                true,
    "forceConsistentCasingInFileNames": true,
    "noEmitOnError":                    true,
    "noImplicitOverride":               false,
    "types": ["node","@webgpu/types"]
  },
  "include": ["src"],
  "exclude": ["node_modules", "src/examples", "test","src/wasm","src/gpu"]
}
